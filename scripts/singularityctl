#!/bin/bash
# Singularity MCP Server - Script de control

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BINARY="$SCRIPT_DIR/singularity"

# Colores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

show_status() {
    if pgrep -f "singularity" > /dev/null; then
        echo -e "${GREEN}✓${NC} Servidor MCP Singularity está corriendo"
        pgrep -f "singularity" | head -1 | xargs ps -p | tail -1
    else
        echo -e "${RED}✗${NC} Servidor MCP Singularity NO está corriendo"
    fi
}

case "${1:-start}" in
    start)
        echo "🚀 Iniciando Singularity MCP Server..."
        
        if pgrep -f "singularity" > /dev/null; then
            echo -e "${YELLOW}El servidor ya está corriendo. Usa 'singularity restart'${NC}"
            show_status
            exit 1
        fi
        
        "$BINARY" &
        echo "✅ Servidor iniciado en background"
        sleep 1
        show_status
        ;;
        
    stop)
        echo "🛑 Deteniendo Singularity MCP Server..."
        pkill -f "singularity" || true
        sleep 1
        echo "✅ Servidor detenido"
        ;;
        
    restart)
        echo "🔄 Reiniciando Singularity MCP Server..."
        pkill -f "singularity" || true
        sleep 1
        "$BINARY" &
        sleep 2
        show_status
        ;;
        
    status)
        show_status
        ;;
        
    logs)
        if pgrep -f "singularity" > /dev/null; then
            PID=$(pgrep -f "singularity" | head -1)
            tail -f /proc/$PID/fd/1 2>/dev/null || echo "No hay logs disponibles"
        else
            echo "El servidor no está corriendo"
        fi
        ;;
        
    *)
        echo "Uso: $0 {start|stop|restart|status|logs}"
        echo ""
        echo "Comandos:"
        echo "  start    - Iniciar el servidor"
        echo "  stop     - Detener el servidor"
        echo "  restart  - Reiniciar el servidor"
        echo "  status   - Mostrar estado del servidor"
        echo "  logs     - Ver logs en tiempo real"
        exit 1
        ;;
esac
